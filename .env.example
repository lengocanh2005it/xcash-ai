# ═══════════════════════════════════════════════════════════
# X-Cash AI — Environment Variables (bản tham chiếu đầy đủ)
# ═══════════════════════════════════════════════════════════
# Split khi setup local (KHÔNG commit file .env thật):
#
#   cp .env.example .env
#   cp apps/backend/.env.example apps/backend/.env
#   cp apps/frontend/.env.example apps/frontend/.env
#
#   .env (root)           → docker compose (POSTGRES_*, REDIS_PORT + biến fullstack)
#   apps/backend/.env     → NestJS + Prisma (`pnpm dev:backend`)
#   apps/frontend/.env    → Vite (`pnpm dev:frontend`) — prefix VITE_ bắt buộc
#
# DATABASE_URL phải khớp POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB / POSTGRES_PORT.

# ───────────────────────────────────────────────────────────
# DOCKER COMPOSE (root .env)
# ───────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=x_cash_ai
POSTGRES_PORT=5432
REDIS_PORT=6379

# ───────────────────────────────────────────────────────────
# APP
# ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ───────────────────────────────────────────────────────────
# DATABASE (PostgreSQL + pgvector)
# ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/x_cash_ai
POSTGRES_HOST=localhost

# ───────────────────────────────────────────────────────────
# REDIS (Cache + BullMQ)
# ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ───────────────────────────────────────────────────────────
# JWT AUTHENTICATION
# ───────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_jwt_access_secret_change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_me
JWT_REFRESH_EXPIRES_IN=7d

# ───────────────────────────────────────────────────────────
# OPENAI API (do công ty cấp sẵn)
# ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ───────────────────────────────────────────────────────────
# CAS SDK — Balance Hook (Banking — SANDBOX THẬT)
# Lấy tại: https://sandbox.console.bankhub.dev/developer/keys
# Docs: https://cas.so/quickstart
# ───────────────────────────────────────────────────────────
CAS_API_BASE_URL=https://sandbox.bankhub.dev
CAS_API_VERSION=2023-01-01
CAS_CLIENT_ID=your_client_id_from_console
CAS_SECRET_KEY=your_secret_key_from_console
CAS_GRANT_REDIRECT_URI=http://localhost:5173/onboarding/callback
# Đổi sang production khi go-live thật:
# CAS_API_BASE_URL=https://production.bankhub.dev

# ───────────────────────────────────────────────────────────
# CAS WEBHOOK (Balance Hook) — 1 URL CHUNG cho toàn App
# Cấu hình tại: sandbox.console.bankhub.dev → Developer → Webhooks
# Loại: TRANSACTIONS
# Dev local: chạy `ngrok http 3000` → điền URL public + /api/v1/webhook/cas
# Ví dụ: https://abc123.ngrok-free.app/api/v1/webhook/cas
CAS_WEBHOOK_URL=

# ───────────────────────────────────────────────────────────
# PAYOS — Billing (X-Cash thu phí nâng cấp gói), không dùng đối soát GD
# ───────────────────────────────────────────────────────────
PAYOS_CHECKSUM_KEY=mock_checksum_for_testing_only
PAYOS_BILLING_WEBHOOK_URL=http://localhost:3000/api/v1/webhook/payos-billing

# ───────────────────────────────────────────────────────────
# WEBHOOK SECURITY
# Docs: https://cas.so/general/api/webhook
# Dev local: đặt WEBHOOK_SKIP_SIGNATURE_VERIFY=true
# Production: bắt buộc false
# ───────────────────────────────────────────────────────────
WEBHOOK_SIGNATURE_HEADER=X-Cas-Signature
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
WEBHOOK_IDEMPOTENCY_TTL_SECONDS=86400
WEBHOOK_SKIP_SIGNATURE_VERIFY=false

# ───────────────────────────────────────────────────────────
# AI CLASSIFICATION
# ───────────────────────────────────────────────────────────
AI_CLASSIFICATION_THRESHOLD=85

# ───────────────────────────────────────────────────────────
# NOTIFICATION
# ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=X-Cash AI <noreply@xcash.ai>
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ───────────────────────────────────────────────────────────
# RATE LIMITING
# ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# ───────────────────────────────────────────────────────────
# LOGGING
# ───────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ───────────────────────────────────────────────────────────
# CORS
# ───────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ───────────────────────────────────────────────────────────
# FRONTEND (apps/frontend/.env — prefix VITE_)
# ───────────────────────────────────────────────────────────
# VITE_API_BASE_URL=http://localhost:3000/api/v1

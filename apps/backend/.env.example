# Backend — NestJS + Prisma (KHÔNG commit file .env thật)
# Copy: cp apps/backend/.env.example apps/backend/.env
# DATABASE_URL phải khớp POSTGRES_* trong .env (root).

# ───────────────────────────────────────────────────────────
# APP
# ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ───────────────────────────────────────────────────────────
# DATABASE (PostgreSQL + pgvector)
# ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/x_cash_ai

# ───────────────────────────────────────────────────────────
# REDIS (Cache + BullMQ)
# ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ───────────────────────────────────────────────────────────
# JWT AUTHENTICATION
# ───────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_jwt_access_secret_change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_me
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_SESSION_EXPIRES_IN=12h

# ───────────────────────────────────────────────────────────
# OPENAI API
# ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
# Primary LLM provider: comma-separated chain (fallback order)
# e.g. "openai,minimax,deepseek,gemini"
COPILOT_LLM_PROVIDER=openai,minimax,deepseek,gemini
# Max tool-calling rounds per agent loop (default 5)
COPILOT_AGENT_MAX_ROUNDS=5
# Max tokens for context window (system prompt + history + user message)
COPILOT_AGENT_MAX_CONTEXT_TOKENS=8000

# ───────────────────────────────────────────────────────────
# FALLBACK PROVIDERS — khi primary fail (429/503/timeout)
# ───────────────────────────────────────────────────────────
# MiniMax (OpenAI-compatible)
MINIMAX_API_KEY=
MINIMAX_CHAT_MODEL=MiniMax-M3
# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_MODEL=deepseek-chat
# Gemini (Google AI OpenAI-compatible)
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
# Jina AI fallback cho embedding (OpenAI-compatible, 1536 dims)
JINA_API_KEY=
JINA_EMBEDDING_MODEL=jina-embeddings-v3
COPILOT_CONTEXT_CACHE_TTL_SECONDS=300
# Phase 3 — tìm kiếm web casso.vn qua Tavily (mặc định tắt)
COPILOT_CASSO_SEARCH_ENABLED=0
# Action-tool đầu tiên của Copilot — đề xuất xác nhận giao dịch (mặc định tắt)
COPILOT_ACTION_TOOLS_ENABLED=0
TAVILY_API_KEY=
TAVILY_TIMEOUT_MS=3000
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=basic

# ───────────────────────────────────────────────────────────
# CAS SDK — https://sandbox.console.bankhub.dev/developer/keys
# ───────────────────────────────────────────────────────────
CAS_API_BASE_URL=https://sandbox.bankhub.dev
# Sandbox → dev.link.bankhub.dev; production → link.bankhub.dev (auto nếu bỏ trống)
CAS_LINK_BASE_URL=https://dev.link.bankhub.dev
CAS_API_VERSION=2023-01-01
CAS_CLIENT_ID=your_client_id_from_console
CAS_SECRET_KEY=your_secret_key_from_console
CAS_GRANT_REDIRECT_URI=http://localhost:5173/onboarding/callback

# ───────────────────────────────────────────────────────────
# Dev local: chạy `ngrok http 3000` → https://<id>.ngrok-free.app/api/v1/webhook/cas
# ───────────────────────────────────────────────────────────
CAS_WEBHOOK_URL=

# ───────────────────────────────────────────────────────────
# PAYOS — Billing
# ───────────────────────────────────────────────────────────
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_BILLING_WEBHOOK_URL=http://localhost:3000/api/v1/webhook/payos-billing

# ───────────────────────────────────────────────────────────
# WEBHOOK SECURITY — dev local: WEBHOOK_SKIP_SIGNATURE_VERIFY=true
# ───────────────────────────────────────────────────────────
WEBHOOK_SIGNATURE_HEADER=X-Cas-Signature
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
WEBHOOK_IDEMPOTENCY_TTL_SECONDS=86400
WEBHOOK_SKIP_SIGNATURE_VERIFY=false

# ───────────────────────────────────────────────────────────
# AI CLASSIFICATION
# ───────────────────────────────────────────────────────────
AI_CLASSIFICATION_THRESHOLD=85

# ───────────────────────────────────────────────────────────
# RATE LIMITING
# ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120

# ───────────────────────────────────────────────────────────
# NOTIFICATION — Resend (email nền qua BullMQ)
# ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_SENDER_EMAIL=noreply@xcash.ai
RESEND_SENDER_NAME=X-Cash AI
EMAIL_OTP_TTL_SECONDS=600
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60
EMAIL_OTP_MAX_ATTEMPTS=5

# Team invite link TTL (seconds, default 7 days)
TEAM_INVITE_TTL_SECONDS=604800
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ───────────────────────────────────────────────────────────
# AZURE BLOB STORAGE — Avatar upload
# ───────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=task-attachments
AZURE_STORAGE_MAX_FILE_SIZE=5242880

# ───────────────────────────────────────────────────────────
# RATE LIMITING
# ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# ───────────────────────────────────────────────────────────
# LOGGING & CORS
# ───────────────────────────────────────────────────────────
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

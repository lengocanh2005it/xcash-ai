# Backend — NestJS + Prisma (KHÔNG commit file .env thật)
# Copy: cp apps/backend/.env.example apps/backend/.env
# DATABASE_URL phải khớp POSTGRES_* trong .env (root).

# ───────────────────────────────────────────────────────────
# APP
# ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ───────────────────────────────────────────────────────────
# DATABASE (PostgreSQL + pgvector)
# ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/paypilot_ai

# ───────────────────────────────────────────────────────────
# REDIS (Cache + BullMQ)
# ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ───────────────────────────────────────────────────────────
# JWT AUTHENTICATION
# ───────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_jwt_access_secret_change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_me
JWT_REFRESH_EXPIRES_IN=7d

# ───────────────────────────────────────────────────────────
# OPENAI API
# ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ───────────────────────────────────────────────────────────
# CAS SDK — https://sandbox.console.bankhub.dev/developer/keys
# ───────────────────────────────────────────────────────────
CAS_API_BASE_URL=https://sandbox.bankhub.dev
CAS_API_VERSION=2023-01-01
CAS_CLIENT_ID=your_client_id_from_console
CAS_SECRET_KEY=your_secret_key_from_console
CAS_GRANT_REDIRECT_URI=http://localhost:5173/onboarding/callback

# ───────────────────────────────────────────────────────────
# Dev local: chạy `ngrok http 3000` → https://<id>.ngrok-free.app/api/v1/webhook/cas
# ───────────────────────────────────────────────────────────
CAS_WEBHOOK_URL=

# ───────────────────────────────────────────────────────────
# PAYOS — Billing
# ───────────────────────────────────────────────────────────
PAYOS_CHECKSUM_KEY=mock_checksum_for_testing_only
PAYOS_BILLING_WEBHOOK_URL=http://localhost:3000/api/v1/webhook/payos-billing

# ───────────────────────────────────────────────────────────
# WEBHOOK SECURITY — dev local: WEBHOOK_SKIP_SIGNATURE_VERIFY=true
# ───────────────────────────────────────────────────────────
WEBHOOK_SIGNATURE_HEADER=X-Cas-Signature
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
WEBHOOK_IDEMPOTENCY_TTL_SECONDS=86400
WEBHOOK_SKIP_SIGNATURE_VERIFY=false

# ───────────────────────────────────────────────────────────
# AI MATCHING
# ───────────────────────────────────────────────────────────
AI_MATCHING_AUTO_THRESHOLD=95
AI_MATCHING_MIN_THRESHOLD=50

# ───────────────────────────────────────────────────────────
# NOTIFICATION
# ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=PayPilot AI <noreply@paypilot.ai>
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ───────────────────────────────────────────────────────────
# RATE LIMITING
# ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# ───────────────────────────────────────────────────────────
# LOGGING & CORS
# ───────────────────────────────────────────────────────────
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

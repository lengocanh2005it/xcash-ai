{
  "name": "@xcash/backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "biome format --write .",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "biome check --write .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:reset": "ts-node --transpile-only prisma/reset.ts",
    "prisma:seed:demo": "ts-node --transpile-only prisma/seed-demo.ts",
    "prisma:seed:notifications": "ts-node --transpile-only prisma/seed-notifications.ts",
    "prisma:seed:partners": "ts-node --transpile-only prisma/seed-partners-demo.ts",
    "seed:knowledge": "ts-node --transpile-only -r tsconfig-paths/register src/scripts/seed-knowledge.ts",
    "migrate:embedding-dims": "ts-node --transpile-only -r tsconfig-paths/register src/scripts/migrate-embedding-dims.ts",
    "eval:copilot-tools": "ts-node --transpile-only -r tsconfig-paths/register src/scripts/eval-copilot-tool-routing.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.28.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "@payos/node": "^2.0.5",
    "@prisma/client": "^6.8.0",
    "@sentry/node": "^10.64.0",
    "@tavily/core": "^0.7.6",
    "@xcash/shared-types": "workspace:*",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.79.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "multer": "^2.0.2",
    "openai": "^6.45.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfmake": "^0.2.20",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.16.0",
    "rxjs": "^7.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "jest": "^30.0.0",
    "prisma": "^6.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "setupFiles": [
      "<rootDir>/../test/jest-setup.ts"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@xcash/shared-types$": "<rootDir>/../../../packages/shared-types/src/index.ts"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}

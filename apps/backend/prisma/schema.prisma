generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum Role {
  cas_partner
  admin
  accountant
  viewer
}

enum TransactionStatus {
  pending
  classified
  review
  skipped
}

enum ClassificationType {
  auto
  manual
}

enum AccountType {
  asset
  liability
  equity
  revenue
  expense
}

enum CasGrantStatus {
  active
  invalidated
}

enum SubscriptionPlan {
  free
  starter
  pro
  enterprise
}

enum SubscriptionStatus {
  active
  suspended
  cancelled
}

enum PaymentOrderStatus {
  pending
  paid
  expired
  failed
}

enum TransactionSource {
  cas
  import
}

enum TransactionDirection {
  in
  out
}

enum NotificationType {
  review_needed
  quota_warning
  quota_exceeded
  overage_started
  billing_success
  billing_payment_due
  tenant_suspended
  copilot_quota_warning
  copilot_quota_exceeded
}

model Tenant {
  id                       String   @id @default(uuid())
  businessName             String   @map("business_name")
  ownerName                String?  @map("owner_name")
  classificationThreshold  Int      @default(85) @map("classification_threshold")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  users                User[]
  transactions         Transaction[]
  auditLogs            AuditLog[]
  casGrants            CasGrant[]
  subscriptions        Subscription[]
  chartOfAccounts      ChartOfAccount[]
  classifications      TransactionClassification[]
  notifications        Notification[]
  importBatches        TransactionImportBatch[]
  copilotConversations CopilotConversation[]
  aiUsageLogs          AiUsageLog[]

  @@map("tenants")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String?   @map("tenant_id")
  name         String
  email        String    @unique
  avatarUrl    String?   @map("avatar_url")
  passwordHash String    @map("password_hash")
  role         Role
  invitedById  String?   @map("invited_by")
  invitedAt    DateTime? @map("invited_at")
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant               Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy            User?                 @relation("UserInvites", fields: [invitedById], references: [id], onDelete: SetNull)
  invites              User[]                @relation("UserInvites")
  notifications        Notification[]
  copilotConversations CopilotConversation[]

  @@index([tenantId])
  @@map("users")
}

model Transaction {
  id              String            @id @default(uuid())
  tenantId        String            @map("tenant_id")
  grantId         String?           @map("grant_id")
  transactionId   String            @unique @map("transaction_id")
  amount          Decimal           @db.Decimal(18, 2)
  senderAccount   String?           @map("sender_account")
  receiverAccount String?           @map("receiver_account")
  content         String?
  transactionDate DateTime             @map("transaction_date")
  status          TransactionStatus    @default(pending)
  source          TransactionSource    @default(cas)
  direction       TransactionDirection @default(in)
  importBatchId   String?              @map("import_batch_id")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  tenant         Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classification TransactionClassification?
  importBatch    TransactionImportBatch?     @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([grantId])
  @@index([tenantId, status])
  @@index([tenantId, source])
  @@index([tenantId, transactionDate])
  @@map("transactions")
}

model TransactionImportBatch {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  fileName      String   @map("file_name")
  totalRows     Int      @map("total_rows")
  importedCount Int      @map("imported_count")
  skippedCount  Int      @map("skipped_count")
  importedBy    String   @map("imported_by")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([tenantId, createdAt])
  @@map("transaction_import_batches")
}

model ChartOfAccount {
  id          String      @id @default(uuid())
  tenantId    String      @map("tenant_id")
  accountCode String      @map("account_code")
  accountName String      @map("account_name")
  accountType AccountType @map("account_type")
  parentCode  String?     @map("parent_code")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, accountCode])
  @@index([tenantId])
  @@map("chart_of_accounts")
}

model TransactionClassification {
  id                 String             @id @default(uuid())
  tenantId           String             @map("tenant_id")
  transactionId      String             @unique @map("transaction_id")
  debitAccount       String             @map("debit_account")
  creditAccount      String             @map("credit_account")
  amount             Decimal            @db.Decimal(18, 2)
  confidenceScore    Int                @map("confidence_score")
  classificationType ClassificationType @map("classification_type")
  classifiedBy       String             @map("classified_by")
  reason             String?
  embedding          Unsupported("vector(1536)")?
  status             TransactionStatus  @default(pending)
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("transaction_classifications")
}

model CasGrant {
  id                String         @id @default(uuid())
  tenantId          String         @map("tenant_id")
  grantId           String         @unique @map("grant_id")
  accessToken       String         @map("access_token")
  accountNumber     String?        @map("account_number")
  accountHolderName String?        @map("account_holder_name")
  bankName          String?        @map("bank_name")
  bankLogo          String?        @map("bank_logo")
  status            CasGrantStatus @default(active)
  linkedAt          DateTime       @default(now()) @map("linked_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("cas_grants")
}

model Subscription {
  id                         String             @id @default(uuid())
  tenantId                   String             @map("tenant_id")
  plan                       SubscriptionPlan   @default(free)
  pricePerMonth              Decimal            @default(0) @map("price_per_month") @db.Decimal(18, 2)
  transactionQuota           Int                @default(50) @map("transaction_quota")
  transactionUsedThisCycle   Int                @default(0) @map("transaction_used_this_cycle")
  copilotUsedThisCycle       Int                @default(0) @map("copilot_used_this_cycle")
  overagePricePerTransaction Decimal?           @map("overage_price_per_transaction") @db.Decimal(18, 2)
  status                     SubscriptionStatus @default(active)
  startedAt                  DateTime           @default(now()) @map("started_at")
  currentCycleStart          DateTime           @default(now()) @map("current_cycle_start")
  currentCycleEnd            DateTime           @map("current_cycle_end")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("subscriptions")
}

model PlanPricing {
  id                         String           @id @default(uuid())
  plan                       SubscriptionPlan @unique
  pricePerMonth              Decimal          @default(0) @map("price_per_month") @db.Decimal(18, 2)
  transactionQuota           Int              @map("transaction_quota")
  copilotQuota               Int              @default(-1) @map("copilot_quota")
  overagePricePerTransaction Decimal?         @map("overage_price_per_transaction") @db.Decimal(18, 2)
  updatedAt                  DateTime         @updatedAt @map("updated_at")

  @@map("plan_pricing")
}

model PaymentOrder {
  id         String             @id @default(uuid())
  tenantId   String             @map("tenant_id")
  orderCode  String             @unique @map("order_code")
  orderType  String             @default("upgrade") @map("order_type")
  targetPlan SubscriptionPlan   @map("target_plan")
  amount     Decimal            @db.Decimal(18, 2)
  status     PaymentOrderStatus @default(pending)
  paidAt     DateTime?          @map("paid_at")
  createdAt  DateTime           @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("payment_orders")
}

model UsageLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  metric     String
  value      Decimal  @db.Decimal(18, 2)
  recordedAt DateTime @default(now()) @map("recorded_at")

  @@index([tenantId])
  @@map("usage_logs")
}

model Notification {
  id        String           @id @default(uuid())
  tenantId  String           @map("tenant_id")
  userId    String?          @map("user_id")
  type      NotificationType
  title     String
  body      String
  link      String?
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, userId, readAt])
  @@index([tenantId, type, createdAt])
  @@map("notifications")
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String?  @map("tenant_id")
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  action      String
  actor       String
  beforeState Json?    @map("before_state")
  afterState  Json?    @map("after_state")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

enum CopilotMessageRole {
  user
  assistant
}

enum AiCallType {
  classify
  copilot
  embedding
  title_gen
}

model CopilotConversation {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  title     String   @default("Cuộc chat mới")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages CopilotMessage[]
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, updatedAt(sort: Desc)])
  @@map("copilot_conversations")
}

model CopilotMessage {
  id             String             @id @default(uuid())
  conversationId String             @map("conversation_id")
  role           CopilotMessageRole
  content        String             @db.Text
  activities     Json?
  isPartial      Boolean            @default(false) @map("is_partial")
  createdAt      DateTime           @default(now()) @map("created_at")

  conversation CopilotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("copilot_messages")
}

model AiUsageLog {
  id             String      @id @default(uuid())
  tenantId       String      @map("tenant_id")
  callType       AiCallType  @map("call_type")
  model          String
  tokensIn       Int         @map("tokens_in")
  tokensOut      Int         @default(0) @map("tokens_out")
  transactionId  String?     @map("transaction_id")
  conversationId String?     @map("conversation_id")
  createdAt      DateTime    @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([callType, createdAt])
  @@map("ai_usage_logs")
}

model KnowledgeEmbedding {
  id        String                 @id @default(uuid())
  sectionId String                 @unique @map("section_id")
  title     String
  content   String
  contentHash String              @map("content_hash")
  embedding Unsupported("vector(1536)")?
  updatedAt DateTime               @default(now()) @updatedAt @map("updated_at")

  @@index([sectionId])
  @@map("knowledge_embeddings")
}

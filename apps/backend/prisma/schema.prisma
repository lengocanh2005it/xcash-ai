generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum Role {
  cas_partner
  admin
  accountant
  viewer
}

enum TransactionStatus {
  pending
  matched
  review
  skipped
}

enum InvoiceStatus {
  unpaid
  partial
  paid
  overpaid
}

enum MatchType {
  auto
  manual
}

enum CasGrantStatus {
  active
  invalidated
}

enum SubscriptionPlan {
  free
  starter
  pro
  enterprise
}

enum SubscriptionStatus {
  active
  suspended
  cancelled
}

enum PaymentOrderStatus {
  pending
  paid
  expired
  failed
}

model Tenant {
  id                 String   @id @default(uuid())
  businessName       String   @map("business_name")
  matchingThreshold  Int      @default(95) @map("matching_threshold")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  users         User[]
  customers     Customer[]
  invoices      Invoice[]
  transactions  Transaction[]
  auditLogs     AuditLog[]
  casGrants     CasGrant[]
  subscriptions Subscription[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String?  @map("tenant_id")
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role
  invitedById  String?  @map("invited_by")
  invitedAt    DateTime? @map("invited_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy User?   @relation("UserInvites", fields: [invitedById], references: [id], onDelete: SetNull)
  invites   User[]  @relation("UserInvites")

  @@index([tenantId])
  @@map("users")
}

model Customer {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  name            String
  phone           String?
  email           String?
  accountNumbers  String[]  @default([]) @map("account_numbers")
  embedding       Unsupported("vector")?
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([tenantId])
  @@map("customers")
}

model Invoice {
  id          String        @id @default(uuid())
  tenantId    String        @map("tenant_id")
  customerId  String        @map("customer_id")
  invoiceCode String        @map("invoice_code")
  amount      Decimal       @db.Decimal(18, 2)
  paidAmount  Decimal       @default(0) @map("paid_amount") @db.Decimal(18, 2)
  status      InvoiceStatus @default(unpaid)
  dueDate     DateTime?     @map("due_date")
  embedding   Unsupported("vector")?
  deletedAt   DateTime?     @map("deleted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  matches InvoiceMatch[]

  @@unique([tenantId, invoiceCode])
  @@index([tenantId])
  @@map("invoices")
}

model Transaction {
  id              String            @id @default(uuid())
  tenantId        String            @map("tenant_id")
  grantId         String?           @map("grant_id")
  transactionId   String            @unique @map("transaction_id")
  amount          Decimal           @db.Decimal(18, 2)
  senderAccount   String?           @map("sender_account")
  receiverAccount String?           @map("receiver_account")
  content         String?
  transactionDate DateTime          @map("transaction_date")
  status          TransactionStatus @default(pending)
  confidenceScore Int?              @map("confidence_score")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matches InvoiceMatch[]

  @@index([tenantId])
  @@index([grantId])
  @@map("transactions")
}

model InvoiceMatch {
  id              String    @id @default(uuid())
  transactionId   String    @map("transaction_id")
  invoiceId       String    @map("invoice_id")
  matchedAmount   Decimal   @map("matched_amount") @db.Decimal(18, 2)
  confidenceScore Int       @map("confidence_score")
  matchType       MatchType @map("match_type")
  matchedBy       String    @map("matched_by")
  createdAt       DateTime  @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  invoice     Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([invoiceId])
  @@map("invoice_matches")
}

model CasGrant {
  id            String         @id @default(uuid())
  tenantId      String         @map("tenant_id")
  grantId       String         @unique @map("grant_id")
  accessToken   String         @map("access_token")
  accountNumber String?        @map("account_number")
  accountHolderName String?    @map("account_holder_name")
  bankName      String?        @map("bank_name")
  bankLogo      String?        @map("bank_logo")
  status        CasGrantStatus @default(active)
  linkedAt      DateTime       @default(now()) @map("linked_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("cas_grants")
}

model Subscription {
  id                         String             @id @default(uuid())
  tenantId                   String             @map("tenant_id")
  plan                       SubscriptionPlan   @default(free)
  pricePerMonth              Decimal            @default(0) @map("price_per_month") @db.Decimal(18, 2)
  transactionQuota           Int                @default(50) @map("transaction_quota")
  transactionUsedThisCycle   Int                @default(0) @map("transaction_used_this_cycle")
  overagePricePerTransaction Decimal?           @map("overage_price_per_transaction") @db.Decimal(18, 2)
  status                     SubscriptionStatus @default(active)
  startedAt                  DateTime           @default(now()) @map("started_at")
  currentCycleStart          DateTime           @default(now()) @map("current_cycle_start")
  currentCycleEnd            DateTime           @map("current_cycle_end")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("subscriptions")
}

model PaymentOrder {
  id         String             @id @default(uuid())
  tenantId   String             @map("tenant_id")
  orderCode  String             @unique @map("order_code")
  targetPlan SubscriptionPlan   @map("target_plan")
  amount     Decimal            @db.Decimal(18, 2)
  status     PaymentOrderStatus @default(pending)
  paidAt     DateTime?          @map("paid_at")
  createdAt  DateTime           @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("payment_orders")
}

model UsageLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  metric     String
  value      Decimal  @db.Decimal(18, 2)
  recordedAt DateTime @default(now()) @map("recorded_at")

  @@index([tenantId])
  @@map("usage_logs")
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String?  @map("tenant_id")
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  action      String
  actor       String
  beforeState Json?    @map("before_state")
  afterState  Json?    @map("after_state")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

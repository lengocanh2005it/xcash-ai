{
  "name": "x-cash-ai",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "verify": "turbo run lint type-check test build",
    "dev:backend": "turbo run dev --filter=@xcash/backend",
    "dev:frontend": "turbo run dev --filter=@xcash/frontend",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,jsonc,css}": "biome check --write --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "turbo": "^2.5.0"
  }
}
